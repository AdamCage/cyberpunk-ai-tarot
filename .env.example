# Скопируй этот файл в .env и заполни
# cp .env.example .env

# ── Модель (одна директория HuggingFace) ──────────────────────────────────────
# Либо repo id: black-forest-labs/FLUX.1-dev
# Либо путь к папке snapshot после: hf download black-forest-labs/FLUX.1-dev
# Пример локального кэша:
# HF_MODEL_PATH=C:/Users/AdamCage/.cache/huggingface/hub/models--black-forest-labs--FLUX.1-dev/snapshots/3de623fc3c33e44ffbe2bad470d0f45bccf2eb21
HF_MODEL_PATH=

# ── Параметры тренировки ─────────────────────────────────────────────────────
TRIGGER_WORD=LoraTrigger

# Полная тренировка
TRAINING_STEPS=1000
TRAINING_RANK=16
TRAINING_LR=1e-4
TRAINING_BATCH_SIZE=1
TRAINING_RESOLUTION_W=960
TRAINING_RESOLUTION_H=1952
TRAINING_NUM_REPEATS=10

# Тестовая тренировка
TEST_STEPS=50
TEST_RANK=4
TEST_RESOLUTION_W=512
TEST_RESOLUTION_H=1024
TEST_NUM_REPEATS=1

# ── ComfyUI генерация (generate_cards_comfyui.py) ────────────────────────────
# Имена файлов моделей КАК ОНИ ВИДНЫ В COMFYUI (не полные пути)
# Скопируй LoRA из output/ в ComfyUI/models/loras/ после тренировки
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_FLUX_UNET=flux1-dev.safetensors
COMFYUI_CLIP_L=clip_l.safetensors
COMFYUI_T5=t5xxl_fp16.safetensors
COMFYUI_VAE=ae.safetensors
# COMFYUI_LORA=cp2077_tarot_lora-000001000.safetensors
